{
  "slug": "example-driver",
  "name": "Example Sensor Driver",
  "version": "1.0.0",
  "description": "Driver for example temperature/humidity sensor hardware",
  "domain_slug": "my-domain",
  "dld_type": "ExampleSensorDLD",
  "protocol": "http",
  "manufacturer": "Example Corp",
  "models": ["EX-TH100", "EX-TH200"],
  "config_schema": {
    "type": "object",
    "properties": {
      "host": { "type": "string", "description": "Sensor IP address or hostname" },
      "port": { "type": "number", "default": 80, "description": "HTTP port" },
      "poll_interval_s": { "type": "number", "default": 30, "description": "Polling interval in seconds" }
    },
    "required": ["host"]
  }
}
